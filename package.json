{
  "name": "@yagelhayun/logger",
  "version": "0.1.0-alpha.8",
  "description": "JSON Logger with superpowers",
  "files": [
    "dist/**",
    "client.*",
    "server.*"
  ],
  "exports": {
    "./client": {
      "types": "./dist/client/index.d.ts",
      "default": "./dist/client/index.js"
    },
    "./server": {
      "types": "./dist/server/index.d.ts",
      "default": "./dist/server/index.js"
    }
  },
  "typesVersions": {
    "*": {
      "client": [
        "dist/client/index.d.ts"
      ],
      "server": [
        "dist/server/index.d.ts"
      ]
    }
  },
  "publishConfig": {
    "registry": "https://npm.pkg.github.com"
  },
  "scripts": {
    "prebuild": "rm -rf dist",
    "build": "tsc",
    "prepack": "rm -f *.tgz && npm run build",
    "test": "vitest run"
  },
  "keywords": [
    "logger",
    "winston",
    "clientlogger",
    "serverlogger"
  ],
  "author": "Yagel Hayun",
  "license": "ISC",
  "dependencies": {
    "lodash.merge": "^4.6.2",
    "winston": "^3.19.0",
    "zod": "^3.25.76"
  },
  "devDependencies": {
    "@nestjs/common": "^7.6.13",
    "@nestjs/core": "^7.6.13",
    "@nestjs/platform-express": "^7.6.18",
    "@nestjs/platform-fastify": "^7.6.18",
    "@types/express": "^4.17.21",
    "@types/lodash.merge": "^4.6.7",
    "@types/node": "^20.11.17",
    "@types/supertest": "^6.0.3",
    "@types/uuid": "^9.0.8",
    "express": "^4.0.0",
    "fastify": "^4.25.2",
    "rxjs": "^6.6.0",
    "supertest": "^7.2.2",
    "typescript": "^5.3.3",
    "vitest": "^2.1.9"
  },
  "peerDependencies": {
    "@nestjs/common": ">=7.0.0"
  },
  "peerDependenciesMeta": {
    "@nestjs/common": {
      "optional": true
    }
  }
}